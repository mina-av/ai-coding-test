# Anthropic (Required for /api/extract and /api/bki/match)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API-Key-Schutz für /api/extract und /api/bki/match (SEC-1)
# Beide Variablen müssen auf denselben Wert gesetzt werden.
# Server-seitig: EXTRACT_API_KEY (geheim)
# Client-seitig: NEXT_PUBLIC_EXTRACT_API_KEY (erscheint im Browser-Bundle)
EXTRACT_API_KEY=your-secret-api-key-here
NEXT_PUBLIC_EXTRACT_API_KEY=your-secret-api-key-here

# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
